# ─── Backend ───────────────────────────────────────────
PORT=3010
FRONTEND_ORIGIN=http://localhost:3000

# ─── vLLM utama (Qwen 72B FP8) — GPU 0 ─────────────────
LLM_MAIN_BASE_URL=http://localhost:8000/v1
LLM_MAIN_MODEL=Qwen/Qwen2.5-72B-Instruct-FP8
LLM_MAIN_API_KEY=sk-local
LLM_MAIN_TEMPERATURE=0.7
LLM_MAIN_MAX_TOKENS=4096

# ─── vLLM cepat (Qwen 32B FP8) — GPU 1 ─────────────────
LLM_FAST_BASE_URL=http://localhost:8001/v1
LLM_FAST_MODEL=Qwen/Qwen2.5-32B-Instruct-FP8
LLM_FAST_TEMPERATURE=0.7
LLM_FAST_MAX_TOKENS=4096

# ─── Profil creative (Qwen 72B + temperatur tinggi) ─────
# default: pakai LLM_MAIN_BASE_URL & LLM_MAIN_MODEL
LLM_CREATIVE_TEMPERATURE=0.85
LLM_CREATIVE_TOP_P=0.95
LLM_CREATIVE_MAX_TOKENS=6144

# ─── Profil reasoning (DeepSeek R1 70B) ────────────────
# default base URL: LLM_MAIN_BASE_URL
LLM_REASON_MODEL=deepseek-ai/DeepSeek-R1-Distill-Llama-70B
LLM_REASON_TEMPERATURE=0.3
LLM_REASON_MAX_TOKENS=8192

# ─── Embedding (Infinity / TEI) ────────────────────────
LLM_EMBED_BASE_URL=http://localhost:8002
LLM_EMBED_MODEL=BAAI/bge-m3
